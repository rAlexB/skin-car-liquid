
{% assign block_settings = block.settings %}
{%- liquid
  assign brand_alt = block_settings.brand_image.alt | default: block_settings.brand_text | default: shop.name
-%}
<div
  class="
    footer-utilities__group-copyright
    custom-typography
    {% if block_settings.font_size != "" %}custom-font-size{% endif %}
  "
  style="{% render 'typography-style', preset: 'custom', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <span class="footer-utilities__text">
    &copy; {{ 'now' | date: '%Y' }}
    {{ shop.name | link_to: routes.root_url -}}
    {%- if block_settings.show_powered_by -%}
      , {{ powered_by_link }}
    {%- endif -%}
    {%- if block_settings.brand_image != blank -%}
      <span
        class="footer-utilities__brand"
        style="--brand-logo-height: {{ block_settings.brand_logo_height }}em;"
      >
        {%- if block_settings.brand_text != blank -%}
          <span class="footer-utilities__brand-label">{{ block_settings.brand_text }}</span>
        {%- endif -%}
        {%- capture brand_logo -%}
          {{
            block_settings.brand_image
            | image_url: height: 160
            | image_tag: class: 'footer-utilities__brand-logo', loading: 'lazy', alt: brand_alt
          }}
        {%- endcapture -%}
        {%- if block_settings.brand_link != blank -%}
          <a
            href="{{ block_settings.brand_link }}"
            class="footer-utilities__brand-link"
            target="_blank"
            rel="noopener"
          >{{ brand_logo | strip }}</a>
        {%- else -%}
          {{ brand_logo | strip }}
        {%- endif -%}
      </span>
    {%- endif -%}
  </span>
</div>

{% stylesheet %}
  .footer-utilities__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    vertical-align: middle;
  }

  .footer-utilities__brand-link {
    display: inline-flex;
    align-items: center;
  }

  .footer-utilities__brand-logo {
    /* Height tracks the copyright text size; width keeps the logo's aspect ratio. */
    height: var(--brand-logo-height, 1.5em);
    width: auto;
    max-width: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.copyright",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "t:settings.show_powered_by_shopify",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "t:content.manage_store_name"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:settings.size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "case",
      "label": "t:settings.case",
      "options": [
        {
          "value": "none",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Agency brand"
    },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Brand image"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Label",
      "info": "Optional text shown before the brand image (e.g. \"Made by\")."
    },
    {
      "type": "url",
      "id": "brand_link",
      "label": "Brand link"
    },
    {
      "type": "range",
      "id": "brand_logo_height",
      "label": "Brand height",
      "info": "Image height relative to the copyright text size.",
      "min": 0.75,
      "max": 4,
      "step": 0.25,
      "unit": "em",
      "default": 1.5
    }
  ],
  "presets": [
    {
      "name": "t:names.copyright",
      "category": "t:categories.footer"
    }
  ]
}
{% endschema %}
