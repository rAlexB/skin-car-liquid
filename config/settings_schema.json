      {
        "type": "header",
        "content": "t:labels.color_background"
      },
      {
        "type": "color",
        "id": "color_background",
        "default": "#FCFCFC",
        "label": "t:labels.color_background"
      },
      {
        "type": "color",
        "id": "color_background_text",
        "default": "#071121",
        "label": "t:labels.color_background_text"
      },
      {
        "type": "header",
        "content": "t:labels.color_highlight"
      },
      {
        "type": "color",
        "id": "color_highlight",
        "default": "#071121",
        "label": "t:labels.color_highlight"
      },
      {
        "type": "color",
        "id": "color_highlight_text",
        "default": "#FFFFFF",
        "label": "t:labels.color_highlight_text"
      },
      {
        "type": "header",
        "content": "t:labels.color_accent"
      },
      {
        "type": "color",
        "id": "color_accent",
        "default": "#0852A5",
