{% comment %}
  Bridge snippet: maps Tinker CSS variables to skin-car section aliases.
  Rendered from theme.liquid after theme-styles-variables and color-schemes.
{% endcomment %}
{% style %}
  @font-face {
    font-family: 'Baradig';
    src: url('{{ 'Baradig-Bold.otf' | asset_url }}') format('opentype');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Baradig';
    src: url('{{ 'Baradig-Regular.otf' | asset_url }}') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Baradig';
    src: url('{{ 'Baradig-Medium.otf' | asset_url }}') format('opentype');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Baradig';
    src: url('{{ 'Baradig-Semibold.otf' | asset_url }}') format('opentype');
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }
  :root {
    --font-brand: 'Baradig', sans-serif;
    --font-brand--family: 'Baradig', sans-serif;
    --font-brand--weight: 700;
    --font-brand--style: normal;
    --page-width: var(--{{ settings.page_width }}-page-width, 90rem);
    --page-margin: 20px;
    --color-background-text: var(--color-foreground);
    --color-highlight: var(--color-primary);
    --color-highlight-text: var(--color-primary-button-text);
    --color-accent: var(--color-primary-button-background);
    --color-accent-text: var(--color-primary-button-text);
    --style-border-radius-buttons: 0;
  }
{% endstyle %}
