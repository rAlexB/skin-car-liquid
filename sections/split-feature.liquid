{% style %}
  #shopify-section-{{ section.id }} .split-feature {
    margin-top: {{ section.settings.margin_top }}rem;
    margin-bottom: {{ section.settings.margin_bottom }}rem;
  }
{% endstyle %}

<div class="split-feature full-width">
  <div class="split-feature__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="split-feature__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="split-feature__grid">

      <div class="split-feature__left">
        {%- if section.settings.video_url != blank -%}
          {%- assign vid = section.settings.video_url -%}
          {%- if vid.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ vid.id }}?autoplay=1&mute=1&loop=1&playlist={{ vid.id }}"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.heading | escape }}"
            ></iframe>
          {%- elsif vid.type == 'vimeo' -%}
            <iframe
              src="https://player.vimeo.com/video/{{ vid.id }}?autoplay=1&muted=1&loop=1"
              allow="autoplay; fullscreen"
              allowfullscreen
              title="{{ section.settings.heading | escape }}"
            ></iframe>
          {%- endif -%}
        {%- elsif section.settings.left_image != blank -%}
          {{ section.settings.left_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600,900,1200', class: 'split-feature__left-img' }}
        {%- endif -%}
      </div>

      <div class="split-feature__right">
        {%- if section.settings.right_image != blank -%}
          <div class="split-feature__right-img-wrap">
            {{ section.settings.right_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400,600,800', class: 'split-feature__right-img' }}
          </div>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <h3 class="split-feature__subheading">{{ section.settings.subheading }}</h3>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="split-feature__text">{{ section.settings.text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a class="split-feature__cta" href="{{ section.settings.cta_url | default: '#' }}">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .split-feature {
    background-color: var(--color-highlight);
    padding-inline: var(--page-margin);
    padding-block: 5rem;
  }

  .split-feature__inner {
    max-width: var(--page-width);
    margin-inline: auto;
  }

  .split-feature__heading {
    text-align: center;
    color: var(--color-highlight-text);
    margin-bottom: 3rem;
  }

  .split-feature__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  /* Left block — image/video fills the column height set by the right column */
  .split-feature__left {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    min-height: 420px;
  }

  .split-feature__left-img,
  .split-feature__left iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  /* Right block — flex column */
  .split-feature__right {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .split-feature__right-img-wrap {
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 16 / 8;
  }

  .split-feature__right-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .split-feature__subheading {
    color: var(--color-highlight-text);
    margin: 0;
  }

  .split-feature__text {
    color: var(--color-highlight-text);
    opacity: 0.85;
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .split-feature__cta {
    display: inline-block;
    align-self: flex-start;
    background-color: var(--color-accent);
    color: var(--color-accent-text);
    padding: 0.75rem 1.75rem;
    border-radius: var(--style-border-radius-inputs);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .split-feature__cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .split-feature__grid {
      grid-template-columns: 1fr;
    }

    .split-feature__left {
      min-height: 280px;
      aspect-ratio: 4 / 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Split Feature",
  "settings": [
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "rem",
      "default": 4
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "rem",
      "default": 4
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Expertise"
    },
    {
      "type": "header",
      "content": "Left block"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL (overrides image if set)",
      "accept": ["youtube", "vimeo"],
      "placeholder": "https://www.youtube.com/watch?v=..."
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Right block"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Heading (H3)",
      "default": "Premium Car Care"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Describe your product or service with a compelling message that turns visitors into customers."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Split Feature"
    }
  ]
}
{% endschema %}
