{% style %}
  #shopify-section-{{ section.id }} .hero__heading {
    font-size: {{ section.settings.heading_size }}rem;
  }
{% endstyle %}

<div class="hero full-width">
  {%- if section.settings.background_image -%}
    <div class="hero__background">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'eager', widths: '600,900,1200,1600,2000' }}
    </div>
  {%- endif -%}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    <div class="hero__text">
      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="hero__body">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var sectionEl = document.getElementById('shopify-section-{{ section.id }}');

    function syncBodyWidth() {
      var heading = sectionEl.querySelector('.hero__heading');
      var body = sectionEl.querySelector('.hero__body');
      if (!heading || !body) return;
      body.style.maxWidth = heading.offsetWidth + 'px';
    }

    document.fonts.ready.then(syncBodyWidth);
    window.addEventListener('resize', syncBodyWidth);
  })();
</script>

{% stylesheet %}
  .hero {
    position: relative;
    height: 100svh;
    display: flex;
    align-items: flex-end;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--color-highlight);
    opacity: 0.45;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-inline: var(--page-margin);
    padding-bottom: 4rem;
    max-width: var(--page-width);
    margin-inline: auto;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero__heading {
    font-weight: bold;
    color: var(--color-highlight-text);
    line-height: 1.1;
    margin: 0;
  }

  .hero__body {
    max-width: 100%;
    margin-top: 1rem;
    color: var(--color-highlight-text);
    font-size: 1.125rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero__heading {
      font-size: 2.5rem !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your headline here"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2,
      "max": 7,
      "step": 0.5,
      "unit": "rem",
      "label": "Heading size",
      "default": 3.5
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Text",
      "default": "A short description that supports your heading and tells visitors what to expect."
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
